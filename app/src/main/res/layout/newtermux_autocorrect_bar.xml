<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/autocorrect_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/nt_surface"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:visibility="gone">

    <TextView
        android:id="@+id/autocorrect_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Did you mean: ls?"
        android:textColor="@color/nt_on_surface"
        android:textSize="14sp"
        android:textStyle="italic" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/autocorrect_apply_button"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Apply"
        android:textColor="@color/nt_primary"
        app:rippleColor="@color/nt_primary_variant" />

    <ImageButton
        android:id="@+id/autocorrect_close_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/nt_on_surface" />

</LinearLayout>
