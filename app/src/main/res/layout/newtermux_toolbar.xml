<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/newtermux_toolbar_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/nt_toolbar_bg">

    <!-- Top bar: app name + feature buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NewTermux"
            android:textColor="@color/nt_toolbar_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- Autocorrect Toggle Button -->
        <TextView
            android:id="@+id/btn_autocorrect_toggle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_package_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="AC"
            android:textColor="@color/nt_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Packages Button -->
        <TextView
            android:id="@+id/btn_packages_menu"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_package_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Packages"
            android:textColor="@color/nt_on_surface"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Clear Button -->
        <TextView
            android:id="@+id/btn_clear_terminal"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_package_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Clear"
            android:textColor="@color/nt_on_surface"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Speech-to-Text button -->
        <ImageButton
            android:id="@+id/btn_stt"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Speech to Text"
            android:src="@drawable/ic_mic"
            android:tint="@color/nt_stt_idle"
            android:padding="10dp" />

        <!-- Root toggle button -->
        <ImageButton
            android:id="@+id/btn_root_toggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Root Toggle"
            android:src="@drawable/ic_root_toggle"
            android:tint="@color/nt_root_inactive"
            android:padding="10dp" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:src="@drawable/ic_settings"
            android:tint="@color/nt_toolbar_icon"
            android:padding="10dp" />

        <!-- New session button -->
        <ImageButton
            android:id="@+id/btn_new_session"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="New Session"
            android:src="@drawable/ic_add_session"
            android:tint="@color/nt_toolbar_icon"
            android:padding="10dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nt_divider" />

    <!-- Session pip row (live mini terminal previews) -->
    <HorizontalScrollView
        android:id="@+id/session_tabs_scroll"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:scrollbars="none"
        android:background="@color/nt_tab_bg">

        <LinearLayout
            android:id="@+id/session_pip_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nt_divider" />

</LinearLayout>
