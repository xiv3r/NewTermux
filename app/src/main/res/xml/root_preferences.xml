<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <Preference
        app:key="newtermux_appearance"
        app:title="Appearance"
        app:summary="Accent color and UI theme"
        app:fragment="com.termux.app.activities.SettingsActivity$AppearancePreferencesFragment"/>

    <Preference
        app:key="package_manager"
        app:title="Package Manager"
        app:summary="Browse installed packages, search and install new ones"
        app:persistent="false" />

    <Preference
        app:key="ssh_manager"
        app:title="SSH Manager"
        app:summary="Save and connect to multiple SSH servers"
        app:persistent="false" />

    <Preference
        app:key="file_manager"
        app:title="File Manager"
        app:summary="Browse, edit, and manage files in your Termux home"
        app:persistent="false" />

    <Preference
        app:key="newtermux_backup"
        app:title="Backup &amp; Restore"
        app:summary="Back up or restore your Termux environment"
        app:fragment="com.termux.app.activities.SettingsActivity$BackupPreferencesFragment"/>

    <Preference
        app:key="newtermux_features"
        app:title="Features"
        app:summary="Toggle NewTermux features on or off"
        app:fragment="com.termux.app.activities.SettingsActivity$FeaturesPreferencesFragment"/>

    <Preference
        app:key="text_expansion"
        app:title="Text Expansion"
        app:summary="Auto-expand short triggers to full commands"
        app:fragment="com.termux.app.activities.SettingsActivity$TextExpansionPreferencesFragment"/>

    <Preference
        app:key="termux"
        app:title="@string/termux_preferences_title"
        app:summary="@string/termux_preferences_summary"
        app:fragment="com.termux.app.fragments.settings.TermuxPreferencesFragment"/>

    <Preference
        app:key="termux_api"
        app:title="@string/termux_api_preferences_title"
        app:summary="@string/termux_api_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxAPIPreferencesFragment"/>

    <Preference
        app:key="termux_float"
        app:title="@string/termux_float_preferences_title"
        app:summary="@string/termux_float_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxFloatPreferencesFragment"/>

    <Preference
        app:key="termux_tasker"
        app:title="@string/termux_tasker_preferences_title"
        app:summary="@string/termux_tasker_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxTaskerPreferencesFragment"/>

    <Preference
        app:key="termux_widget"
        app:title="@string/termux_widget_preferences_title"
        app:summary="@string/termux_widget_preferences_summary"
        app:isPreferenceVisible="false"
        app:fragment="com.termux.app.fragments.settings.TermuxWidgetPreferencesFragment"/>

    <Preference
        app:key="about"
        app:title="@string/about_preference_title"
        app:persistent="false"/>
    <!-- app:layout="@layout/preference_markdown_text" -->

    <Preference
        app:key="donate"
        app:title="@string/donate_preference_title"
        app:persistent="false"
        app:isPreferenceVisible="false"/>

</PreferenceScreen>
