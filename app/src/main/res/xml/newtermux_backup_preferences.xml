<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory app:title="Backup">
        <Preference
            app:key="basic_backup_now"
            app:title="Basic Backup"
            app:summary="Save personal files only (home) — /sdcard/Download/termux-home-backup.tar.gz"
            app:persistent="false" />
        <Preference
            app:key="full_backup_now"
            app:title="Full Backup"
            app:summary="Save files + installed packages (home &amp; usr) — /sdcard/Download/termux-full-backup.tar.gz"
            app:persistent="false" />
    </PreferenceCategory>
    <PreferenceCategory app:title="Restore">
        <Preference
            app:key="restore_now"
            app:title="Restore"
            app:summary="Pick a backup file from your device to restore from"
            app:persistent="false" />
    </PreferenceCategory>
</PreferenceScreen>
